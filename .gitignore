# =============================================================================
# Symbiotic Theme — .gitignore
# Full WordPress installation tracked. Only local/sensitive files excluded.
# =============================================================================

# ── Secrets ─────────────────────────────────────────────────────────────────
wp-config.php
.htaccess
.env
.env.*

# ── Uploads & User Media ───────────────────────────────────────────────────
wp-content/uploads/
wp-content/upgrade/

# ── Logs ────────────────────────────────────────────────────────────────────
wp-content/debug.log
*.log

# ── Node Modules ────────────────────────────────────────────────────────────
node_modules/
.vite/
*.tsbuildinfo

# ── OS Files ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ── IDE / Editor ────────────────────────────────────────────────────────────
.obsidian/
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Claude Code local settings ──────────────────────────────────────────────
.claude/

# ── Working files (not part of the project) ─────────────────────────────────
axiom_extracted.json
printing_product_calculation_summary.md
